FRAUD_PUBLIC_BASE_URL=http://127.0.0.1:8000
N8N_NOTIFY_WEBHOOK_URL=http://n8n:5678/webhook/fraudguard-notify
N8N_WEBHOOK_AUTH_HEADER_NAME=
N8N_WEBHOOK_AUTH_HEADER_VALUE=
N8N_WEBHOOK_TIMEOUT_SECONDS=20

N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Europe/Paris

GROQ_API_KEY=REPLACE_WITH_YOUR_GROQ_API_KEY
FRAUD_GROQ_MODEL=openai/gpt-oss-20b

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=REPLACE_WITH_YOUR_GMAIL
SMTP_PASSWORD=REPLACE_WITH_YOUR_GOOGLE_APP_PASSWORD
SMTP_FROM_EMAIL=REPLACE_WITH_YOUR_GMAIL
SMTP_USE_TLS=true
